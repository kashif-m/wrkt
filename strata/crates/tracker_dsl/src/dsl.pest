// DSL Grammar for tracker definitions
// Grammar file for pest parser

// Top-level structure
tracker_def = { "tracker" ~ identifier ~ version? ~ "{" ~ body ~ "}" }

version = { "v" ~ number ~ ("\." ~ number)* }

body = { (fields_section | derive_section | metrics_section | alerts_section | planning_section)* }

// Fields section
fields_section = { "fields" ~ "{" ~ field_def ~ ("," ~ field_def)* ~ ","? ~ "}" }

field_def = { identifier ~ ":" ~ type_name ~ ("=" ~ literal)? }

type_name = { "string" | "number" | "int" | "bool" | "duration" | "timestamp" | enum_type }

enum_type = { "enum" ~ "(" ~ string_literal ~ ("," ~ string_literal)* ~ ")" }

// Derive section
derive_section = { "derive" ~ "{" ~ derive_expr ~ ("," ~ derive_expr)* ~ ","? ~ "}" }

derive_expr = { identifier ~ "=" ~ expression }

// Metrics section
metrics_section = { "metrics" ~ "{" ~ metric_def ~ ("," ~ metric_def)* ~ ","? ~ "}" }

metric_def = { identifier ~ "=" ~ aggregation_expr }

aggregation_expr = { aggregation_func ~ "(" ~ expression? ~ ")" ~ group_by_clause? }

aggregation_func = { "sum" | "max" | "min" | "avg" | "count" }

group_by_clause = { "by" ~ group_dimension ~ ("," ~ group_dimension)* }

group_dimension = { identifier | time_grain }

time_grain = { "day" | "week" | "month" | "quarter" | "year" }

// Alerts section
alerts_section = { "alerts" ~ "{" ~ alert_def ~ ("," ~ alert_def)* ~ ","? ~ "}" }

alert_def = { identifier ~ "=" ~ condition }

// Planning section
planning_section = { "planning" ~ "{" ~ planning_body ~ "}" }

planning_body = { strategy_list | planner_def* }

strategy_list = { "strategies" ~ "=" ~ "[" ~ identifier ~ ("," ~ identifier)* ~ "]" }

planner_def = { "strategy" ~ identifier ~ "{" ~ planner_param* ~ "}" }

planner_param = { identifier ~ "=" ~ literal }

// Expressions
expression = { conditional | binary_expr | unary_expr | primary }

conditional = { "if" ~ condition ~ "then" ~ expression ~ "else" ~ expression }

condition = { comparison | logical_expr | "(" ~ condition ~ ")" }

comparison = { expression ~ comp_op ~ expression }

comp_op = { "==" | "!=" | "<" | "<=" | ">" | ">=" }

logical_expr = { condition ~ log_op ~ condition | "!" ~ condition }

log_op = { "&&" | "||" }

binary_expr = { expression ~ bin_op ~ expression }

bin_op = { "+" | "-" | "*" | "/" | "%" }

unary_expr = { ("-" | "!") ~ expression }

primary = { literal | field_ref | "(" ~ expression ~ ")" | function_call }

field_ref = { identifier ~ ("." ~ identifier)* }

function_call = { identifier ~ "(" ~ (expression ~ ("," ~ expression)*)? ~ ")" }

// Literals
literal = { string_literal | number | bool_literal | "null" }

string_literal = ${ "\"" ~ inner_string ~ "\"" }

inner_string = @{ char* }

char = { !("\" | "\\") ~ ANY | "\\" ~ ("\" | "\\" | "/" | "b" | "f" | "n" | "r" | "t") | "\\u" ~ ASCII_HEX_DIGIT{4} }

number = @{ "-"? ~ int ~ ("." ~ frac)? ~ exp? | "-"? ~ "." ~ frac ~ exp? }
int = @{ "0" | ASCII_NONZERO_DIGIT ~ ASCII_DIGIT* }
frac = @{ ASCII_DIGIT+ }
exp = @{ ("e" | "E") ~ ("+" | "-")? ~ ASCII_DIGIT+ }

bool_literal = { "true" | "false" }

// Identifiers
identifier = @{ ASCII_ALPHA ~ (ASCII_ALPHANUMERIC | "_")* }

// Whitespace and comments
WHITESPACE = _{ " " | "\t" | "\n" | "\r" }

COMMENT = _{ "//" ~ (!"\n" ~ ANY)* | "/*" ~ (!"*/" ~ ANY)* ~ "*/" }
